/*******************************
     User Global Variables
*******************************/
@fg: #fcfcfa;
@bg: #2d2a2e;

@dark:  #221f22;
@light: #403e41;
@lighter: #727072;

@fontName: "JetBrains Mono";
@textColor: @fg;
@pageBackground: @bg;

@primaryColor: @green;
@secondaryColor: @orange;

@orange: #FC9867;
@green: #A9DC76;
@violet: #ab9df2;
@black: #19181a;
@grey: #727072;
@red: #ff6188;
@yellow: #ffd866;
@blue: #78dce8;
